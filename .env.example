# FavGallery 環境変数サンプル。`cp .env.example .env` してから値を埋める。
# すべて任意 — 未設定でもゼロ設定（認証なし・ローカル保存）で起動する。

# ── Basic 認証 ───────────────────────────────────────────
# 両方を設定したときだけ認証が有効になる。インターネット公開時は必須。
# 片方でも空だと認証は無効＝URL を知る誰もがアクセスできてしまうので注意。
FAVGALLERY_USER=
FAVGALLERY_PASSWORD=

# ── ライブラリ保存先 ─────────────────────────────────────
# メディア・SQLite DB・cookies の置き場所。未設定なら ./data/library。
# Docker / Railway では /data/library（ボリュームマウント先）を推奨。
FAVGALLERY_LIBRARY_ROOT=

# ── Cloudflare R2（任意・S3 互換ストレージ）──────────────
# 4 つすべて揃って初めて R2 保存が有効になる。1 つでも欠けるとローカル保存のみ。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── X cookies 初期投入（任意）────────────────────────────
# cookies.txt（Netscape 形式）の中身を貼り付けると起動時に書き出される
# （既存があれば上書きしない）。通常はアプリ UI（⚙ → 🔑）で設定すればよい。
GALLERY_DL_COOKIES=

# ── 自動同期（任意）──────────────────────────────────────
# ページ読み込み時の自動同期。既定 on。重い/不要なら 0 にして無効化。
FAVGALLERY_AUTOSYNC_ON_LOAD=1
